# ─────────────────────────────────────────────────────────────────────────────
# Example environment for the Fortune API (apps/api). Copy to apps/api/.env.
# NEVER commit real secrets. Variable names match apps/api/src/config/env.schema.ts.
# In production the schema FAILS FAST without: CORS_ALLOWED_ORIGINS (when Swagger
# is on), TELEGRAM_BOT_TOKEN, JWT_PRIVATE_KEY + JWT_PUBLIC_KEY, and
# LLM_BASE_URL + LLM_API_KEY (no mock readings in production).
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development            # development | test | staging | production
APP_NAME=fortune-api
APP_HOST=0.0.0.0
APP_PORT=3000
API_PREFIX=api                 # routes are served under /${API_PREFIX}/v${API_VERSION}
API_VERSION=1                  # → base path /api/v1

# PostgreSQL (required)
DATABASE_URL=postgresql://fortune:fortune@localhost:5432/fortune_dev?schema=public

# Redis (required)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_TLS=false

# Logging / docs
LOG_LEVEL=info                 # debug | info | warn | error
ENABLE_PRETTY_LOGS=false
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# CORS — REQUIRED in production (comma-separated HTTPS origins of the web build).
# For a Telegram Mini App this is your frontend origin, e.g. https://app.example.com
CORS_ALLOWED_ORIGINS=

# Limits
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120

# JWT — asymmetric only (EdDSA/ed25519 or RS256), PEM format. REQUIRED in prod.
# Generate an ed25519 pair:
#   openssl genpkey -algorithm ed25519 -out jwt_private.pem
#   openssl pkey -in jwt_private.pem -pubout -out jwt_public.pem
# Then paste the PEM contents (newlines preserved) into the two vars below.
JWT_ISSUER=fortune-app
JWT_AUDIENCE=fortune-clients
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Telegram Mini App auth (required in production)
TELEGRAM_BOT_TOKEN=            # from @BotFather; verifies initData, never shipped to client
TELEGRAM_BOT_USERNAME=         # optional, e.g. fortune_demo_bot
AUTH_TOKEN_TTL_SECONDS=86400
TELEGRAM_INITDATA_MAX_AGE_SECONDS=3600

# Feature flags source
FEATURE_FLAGS_SOURCE=env       # env | database

# LLM — OpenAI-compatible /chat/completions endpoint (server-side only, REQUIRED in prod)
# Supported (any OpenAI-compatible base URL): OpenAI, Azure OpenAI, OpenRouter,
# Together, Groq, DeepSeek, Mistral, Fireworks, or a local Ollama/LM Studio.
LLM_BASE_URL=                  # e.g. https://api.openai.com/v1
LLM_API_KEY=                   # server-side secret
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=20000
LLM_MAX_RETRIES=1

# Economy
WALLET_STARTER_COINS=30
WALLET_READING_COST=5

# ─────────────────────────────────────────────────────────────────────────────
# Mobile (apps/mobile) — NOT a .env file. Passed at build time via --dart-define.
# Production web build (Telegram Mini App):
#   flutter build web --release -t lib/main_production.dart \
#     --dart-define=API_BASE_URL=https://<API_DOMAIN>/api/v1 \
#     --dart-define=TELEGRAM_BOT_USERNAME=<bot_username>
# NEVER pass DEV_TELEGRAM_INITDATA in production (it is honored only in the dev flavor).
#   API_BASE_URL              → the HTTPS API base, MUST end with /api/v1
#   TELEGRAM_BOT_USERNAME     → optional
#   API_CONNECT_TIMEOUT_MS    → default 15000
#   API_RECEIVE_TIMEOUT_MS    → default 20000
#   ENABLE_ANALYTICS          → default false
#   ENABLE_CRASH_REPORTING    → default false
#   ENABLE_DEBUG_MENU         → default false
# ─────────────────────────────────────────────────────────────────────────────
