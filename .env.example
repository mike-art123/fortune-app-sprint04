# ── Root example env. Copy to .env per app. NEVER commit real secrets. ──

# API (apps/api)
NODE_ENV=development
API_PORT=3000
API_GLOBAL_PREFIX=v1

# PostgreSQL
DATABASE_URL=postgresql://fortune:fortune@localhost:5432/fortune_dev?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (use long random values in real environments)
JWT_ACCESS_SECRET=change_me_dev_access
JWT_REFRESH_SECRET=change_me_dev_refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Telegram Mini App auth
TELEGRAM_BOT_TOKEN=

# AI proxy (server-side only)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=20000
LLM_MAX_RETRIES=1

# Mobile (apps/mobile) — provided via --dart-define, see README
# API_BASE_URL=http://localhost:3000/v1
