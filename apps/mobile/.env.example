# Flutter values are passed via --dart-define, not a committed .env.
# This file documents the accepted keys. NEVER put real secrets in the client.
APP_FLAVOR=development
API_BASE_URL=http://localhost:3000/api/v1
API_CONNECT_TIMEOUT_MS=15000
API_RECEIVE_TIMEOUT_MS=20000
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false
ENABLE_DEBUG_MENU=true
TELEGRAM_BOT_USERNAME=
