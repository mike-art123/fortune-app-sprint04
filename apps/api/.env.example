# ── apps/api environment (doc 52 §9). Copy to .env — never commit secrets. ──
NODE_ENV=development
APP_NAME=fortune-api
APP_HOST=0.0.0.0
APP_PORT=3000
API_PREFIX=api
API_VERSION=1

DATABASE_URL=postgresql://fortune:fortune@localhost:5432/fortune_dev?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false

QUEUE_PREFIX=fortune

LOG_LEVEL=info
ENABLE_PRETTY_LOGS=true

SWAGGER_ENABLED=true
SWAGGER_PATH=docs

CORS_ALLOWED_ORIGINS=http://localhost:5173

REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120

JWT_ISSUER=fortune-app
JWT_AUDIENCE=fortune-clients
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Sprint 04 auth (doc 53). Production refuses to boot without the bot token
# and a persistent JWT keypair (PEM; store newlines as \n).
AUTH_TOKEN_TTL_SECONDS=86400
TELEGRAM_INITDATA_MAX_AGE_SECONDS=3600

FEATURE_FLAGS_SOURCE=env

# AI provider (server-side only — keys never reach the client)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=20000
LLM_MAX_RETRIES=1

# Wallet economy (backend-authoritative; tune without code changes)
WALLET_STARTER_COINS=30
WALLET_READING_COST=5
